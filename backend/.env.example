# Backend environment variables. Copy to `.env` and fill in real values.
# `.env` is gitignored; this `.env.example` is committed as documentation.

# --- Runtime ---
NODE_ENV=development            # development | production
PORT=3000
LOG_LEVEL=info
OUTPUT_RETENTION_DAYS=90        # optional; cleanup age for generated outputs

# --- App secrets (generate strong random values; never commit real ones) ---
JWT_SECRET=                     # reserved; not currently used by request handling
WEBHOOK_SECRET=                 # HMAC secret for /api/webhooks signature verification
CLEANUP_SECRET=                 # bearer secret guarding the scheduled cleanup endpoint

# --- Database (PostgreSQL) ---
# For LOCAL Supabase CLI, both point at the local container. Append ?sslmode=disable
# because the rate-limiter's pg pool otherwise negotiates SSL, which local PG rejects.
# In PRODUCTION use a TLS-enabled connection string and DO NOT set sslmode=disable.
DATABASE_URL=postgresql://user:password@host:5432/postgres?sslmode=disable
DIRECT_URL=postgresql://user:password@host:5432/postgres?sslmode=disable

# --- Supabase (auth + storage) ---
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=              # anon/public key
SUPABASE_SERVICE_ROLE_KEY=      # service-role key (bypasses RLS; keep secret)
S3_BUCKET=templates             # required at startup; the storage adapter uses hardcoded "templates"/"outputs" buckets

# --- Frontend origin (CORS allow-list + password-reset redirect) ---
FRONTEND_URL=http://localhost:5173

# --- Document conversion binaries ---
# LibreOffice powers DOCX/XLSX/PPTX -> PDF/JPG.
SOFFICE_BIN=C:\Program Files\LibreOffice\program\soffice.exe   # Windows; on Linux/macOS this is usually just `soffice`
# PUPPETEER_EXECUTABLE_PATH=    # leave unset to use Puppeteer's bundled Chromium (HTML -> PDF/JPG)
