generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

/// *
///  * User model - Supabase Auth integration, owner of templates/jobs, with roles, standard fields
model User {
    id               String     @id @default(cuid())
    email            String     @unique
    username         String?    @unique
    password         String?    // Nullable - password managed by Supabase Auth
    supabaseId       String?    @unique // Supabase Auth user ID
    role             UserRole   @default(user)
    isActive         Boolean    @default(true)
    firstName        String?
    lastName         String?
    createdAt        DateTime   @default(now())
    updatedAt        DateTime   @updatedAt
    lastLogin        DateTime?
    mergeJobs        MergeJob[] @relation("UserMergeJobs")
    createdTemplates Template[] @relation("UserTemplates")
    folders          Folder[]   @relation("UserFolders")

    @@index([email])
    @@index([isActive])
    @@index([supabaseId])
}

/// *
///  * Folder model - hierarchical organization for templates with max depth of 4
model Folder {
    id        String   @id @default(cuid())
    name      String
    parentId  String?
    depth     Int
    userId    String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    parent    Folder?    @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
    children  Folder[]   @relation("FolderHierarchy")
    templates Template[]
    user      User       @relation("UserFolders", fields: [userId], references: [id])

    @@unique([userId, parentId, name])
    @@index([userId])
    @@index([parentId])
    @@index([userId, parentId])
}

/// *
///  * Template model - file metadata (display name + storage key) + relation to Field[] and MergeJob
model Template {
    id                String       @id @default(cuid())
    mimeType          String?
    displayName       String       // User-friendly name shown in UI (e.g. "sample.docx")
    storageKey        String       // Unique S3 key with timestamp/UUID (e.g. "1234567890-uuid-sample.docx")
    uploadedById      String?
    folderId          String?
    isActive          Boolean      @default(true)
    defaultOutputType OutputType?  // Default output format for merges (e.g. pdf, docx)
    outputNameFormat  String?      // Template for output filename (e.g. "{{firstName}}-{{lastName}}")
    pageSize          PageSize?    // Page size for output (e.g. letter, a4)
    orientation       Orientation? // Page orientation (portrait or landscape)
    createdAt         DateTime          @default(now())
    updatedAt         DateTime          @updatedAt
    fields            Field[]
    jobs              MergeJob[]
    versions          TemplateVersion[]
    uploadedBy        User?             @relation("UserTemplates", fields: [uploadedById], references: [id])
    folder            Folder?           @relation(fields: [folderId], references: [id], onDelete: SetNull)

    @@index([uploadedById])
    @@index([isActive])
    @@index([folderId])
}

/// *
///  * TemplateVersion model - stores historical versions of templates for version control
model TemplateVersion {
    id                String       @id @default(cuid())
    templateId        String
    versionNumber     Int          // Auto-incremented per template
    storageKey        String       // S3 key of the version's file
    mimeType          String
    displayName       String
    defaultOutputType OutputType?
    outputNameFormat  String?
    pageSize          PageSize?
    orientation       Orientation?
    fieldsSnapshot    Json         // Snapshot of fields at version time
    createdAt         DateTime     @default(now())
    expiresAt         DateTime     // 30 days from createdAt

    template          Template     @relation(fields: [templateId], references: [id], onDelete: Cascade)

    @@unique([templateId, versionNumber])
    @@index([templateId, createdAt])
    @@index([expiresAt])
}

/// *
///  * Field model - each placeholder name per template (unique per template)
model Field {
    id         String   @id @default(cuid())
    name       String
    templateId String
    template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

    @@unique([templateId, name])
}

/// *
///  * MergeJob model - audit trail of merges (data, outputType, status, filePath, userId, relations)
model MergeJob {
    id         Int        @id @default(autoincrement())
    templateId String
    userId     String?
    data       Json
    outputType OutputType
    status     JobStatus  @default(queued)
    filePath   String
    error      String?
    createdAt  DateTime   @default(now())
    updatedAt  DateTime   @updatedAt
    template   Template   @relation(fields: [templateId], references: [id], onDelete: Cascade)
    user       User?      @relation("UserMergeJobs", fields: [userId], references: [id])

    @@index([templateId])
    @@index([status, createdAt])
    @@index([userId])
}

/// *
///  * ENUM for OutputType, JobStatus, UserRole, PageSize, Orientation - fixed list of allowed values for a field
enum OutputType {
    docx
    html
    pdf
    xlsx
    pptx
    ppsx
    jpg
}

enum PageSize {
    letter
    legal
    a4
    a3
    tabloid
}

enum Orientation {
    portrait
    landscape
}

enum JobStatus {
    queued
    processing
    succeeded
    failed
}

enum UserRole {
    user
    admin
}

/// *
///  * ErrorLog model - stores application errors for debugging and monitoring
model ErrorLog {
    id        String   @id @default(cuid())
    level     String   // "error", "warn", "info"
    message   String
    stack     String?  @db.Text
    context   Json?    // Request context, user info, error details, etc.
    createdAt DateTime @default(now())

    @@index([level])
    @@index([createdAt])
    @@index([level, createdAt])
}
